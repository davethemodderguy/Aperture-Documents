# Obsidian system folders
.obsidian/workspace.json
.obsidian/cache
.obsidian/plugins/**/data.json

# Optional: ignore most plugin and UI state (recommended)
.obsidian/

# Trash / temporary folders (Obsidian and plugins)
.trash/
.space/

# OS junk
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp

# Log files
*.log

# Optional: if you don’t want to track backups or exports
backups/
export/